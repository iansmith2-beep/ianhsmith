    <style>
/* 1. THE SETUP */
* {
  box-sizing: border-box;
}

p {
  margin: 0;
  margin-bottom: 15px;
}

body {
  background-color: #f1f5f9;
  display: grid;
  gap: 20px;
  grid-template-columns: 1fr;
  margin: 0;
  min-height: 100vh;
  padding: 20px 0;
  place-items: center;
}

.slide-container {
  align-items: center;
  background-color: #ffffff;
  border-radius: 8px;
  box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  font-family: 'Lato', sans-serif;
  height: 720px;
  justify-content: center;
  overflow: hidden;
  padding: 60px;
  position: relative;
  width: 1280px;
  border: 1px solid #e2e8f0;
}

.slide-container::before {
  content: '';
  height: 100%;
  left: 0;
  position: absolute;
  top: 0;
  width: 100%;
  z-index: 0;
}

.slide-container > * {
  position: relative;
  z-index: 1;
}

/* 2. CONSISTENT TYPOGRAPHY */
.slide-container h1,
.slide-container h2,
.slide-container h3 {
  color: #0f172a;
  font-weight: 700;
  font-family: 'Poppins', sans-serif;
  margin: 0;
}

.slide-container p,
.slide-container li,
.slide-container .subtitle,
.slide-container th,
.slide-container td,
.slide-container .bleed-text-side p {
  color: #475569;
  font-family: 'Lato', sans-serif;
}

.slide-container h1 {
  font-size: 70px;
  line-height: 1.1;
  margin-bottom: 20px;
}

.slide-container .slide-title {
  font-size: 40px;
  font-weight: 600;
  margin-bottom: 40px;
  text-align: left;
  width: 100%;
  color: #0f172a;
}

.slide-container h3 {
  font-size: 28px;
  font-weight: 600;
  margin-bottom: 15px;
  color: #1e293b;
}

.slide-container p,
.slide-container li,
.slide-container th,
.slide-container td,
.slide-container .bleed-text-side p {
  font-size: 18px;
  line-height: 1.6;
}

.slide-container .subtitle {
  font-size: 24px;
  font-weight: 400;
  margin: 0 auto;
  color: #334155;
  max-width: 800px;
}

.slide-container .content-area {
  align-items: center;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
  justify-content: flex-start;
  width: 100%;
}

/* 3. LAYOUT DEFINITIONS */
.title-layout {
  text-align: center;
}

.title-layout .department-badge {
  display: inline-block;
  background-color: #eff6ff;
  color: #2563eb;
  font-weight: 700;
  font-size: 16px;
  padding: 8px 16px;
  border-radius: 20px;
  margin-bottom: 20px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.two-column {
  align-items: flex-start;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 50px;
  width: 100%;
}

.two-column.tiled {
  align-items: stretch;
}

.two-column.tiled > div {
  background-color: #f8fafc;
  border-radius: 12px;
  border: 1px solid #e2e8f0;
  padding: 40px;
  text-align: left;
  display: flex;
  flex-direction: column;
}

.two-column.tiled h3 {
  color: #2563eb;
  border-bottom: 2px solid #e2e8f0;
  padding-bottom: 15px;
  margin-bottom: 20px;
}

.two-column ul {
  list-style: disc;
  margin: 0;
  padding-left: 25px;
}

.two-column li {
  margin-bottom: 15px;
}

.image-wrapper {
  border-radius: 12px;
  height: 400px;
  max-width: 100%;
  overflow: hidden;
  width: 100%;
  border: 1px solid #e2e8f0;
}

.image-wrapper img {
  height: 100%;
  max-width: 100%;
  object-fit: cover;
  width: 100%;
}

.two-column .image-wrapper img {
  object-fit: cover;
}

.tiled-content {
  align-items: stretch;
  display: flex;
  gap: 30px;
  justify-content: center;
  width: 100%;
}

.tile {
  align-items: center;
  background-color: #f8fafc;
  border-radius: 12px;
  border: 1px solid #e2e8f0;
  display: flex;
  flex-direction: column;
  flex: 1;
  justify-content: flex-start;
  padding: 40px 30px;
  text-align: center;
}

.tile .icon {
  color: #2563eb;
  font-size: 48px;
  margin-bottom: 25px;
}

.tile h3 {
  font-size: 24px;
}

.bullet-list {
  max-width: 1000px;
  width: 100%;
  align-self: center;
}

.bullet-list ul {
  list-style: none;
  margin: 0;
  padding: 0;
}

.bullet-list li {
  background-color: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  margin-bottom: 20px;
  padding: 20px 20px 20px 60px;
  position: relative;
}

.bullet-list i {
  color: #2563eb;
  font-size: 24px;
  left: 20px;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
}

.bullet-list li strong {
  color: #0f172a;
  font-weight: 700;
  display: block;
  font-size: 20px;
  margin-bottom: 5px;
  font-family: 'Poppins', sans-serif;
}

/* Section Title */
.section-title-layout {
  align-items: center;
  display: flex;
  flex-direction: column;
  height: 100%;
  justify-content: center;
  text-align: center;
  width: 100%;
}

.section-title-layout h2 {
  font-size: 60px;
  margin-bottom: 20px;
  color: #0f172a;
}

.section-title-layout p {
  font-size: 24px;
  margin: 0 auto;
  max-width: 700px;
}

.section-title-layout hr {
  background-color: #2563eb;
  border: none;
  height: 6px;
  margin: 30px auto;
  width: 80px;
  border-radius: 3px;
}

/* Table Layout */
.table-layout {
  width: 100%;
  background-color: #fff;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid #e2e8f0;
}

.table-layout table {
  border-collapse: collapse;
  width: 100%;
}

.table-layout th,
.table-layout td {
  border-bottom: 1px solid #e2e8f0;
  padding: 20px 24px;
  text-align: left;
}

.table-layout th {
  background-color: #f8fafc;
  color: #0f172a;
  font-size: 16px;
  font-weight: 700;
  font-family: 'Poppins', sans-serif;
  border-bottom: 2px solid #cbd5e1;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.table-layout tr:last-child td {
  border-bottom: none;
}

.table-layout td.solution {
  font-weight: 700;
  color: #2563eb;
}

.table-layout td.deliverable {
  font-weight: 500;
  color: #0f172a;
}

.table-layout td span.cross-functional {
  background-color: #fef08a;
  color: #854d0e;
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  display: inline-block;
  margin-bottom: 8px;
}

/* Timeline Layout */
.timeline-layout {
  align-items: stretch;
  display: flex;
  height: stretch;
  justify-content: space-between;
  position: relative;
  width: 100%;
  margin-top: 40px;
}

.timeline-layout .timeline-line {
  background-color: #cbd5e1;
  height: 4px;
  left: 0;
  position: absolute;
  top: 50%;
  transform: translateY(-2px);
  width: 100%;
  z-index: 0;
}

.timeline-item {
  position: relative;
  text-align: center;
  width: 23%;
}

.timeline-item::after {
  background-color: #fff;
  border-radius: 50%;
  border: 4px solid #2563eb;
  content: '';
  height: 24px;
  left: 50%;
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 24px;
  z-index: 1;
}

.timeline-item .content-wrapper {
  left: 0;
  position: absolute;
  width: 100%;
  background-color: #f8fafc;
  padding: 20px;
  border-radius: 8px;
  border: 1px solid #e2e8f0;
}

.timeline-item:nth-child(odd) .content-wrapper {
  bottom: 50%;
  margin-bottom: 35px;
}

.timeline-item:nth-child(even) .content-wrapper {
  margin-top: 35px;
  top: 50%;
}

.timeline-item h3 {
  color: #0f172a;
  font-size: 20px;
  margin-bottom: 10px;
}

.timeline-item p {
  font-size: 16px;
  line-height: 1.4;
  margin: 0;
}

/* Q&A Layout */
.qa-layout {
  margin: 0 auto;
  text-align: center;
  width: 100%;
  align-self: center;
}

.qa-layout h2 {
  font-size: 80px;
  margin-bottom: 20px;
  color: #0f172a;
}

.qa-layout p {
  font-size: 24px;
  color: #475569;
}

.qa-layout .contact-info {
  background-color: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  color: #0f172a;
  font-size: 20px;
  font-weight: 700;
  margin-top: 40px;
  padding: 20px;
  display: inline-block;
}

/* Bleed_Image_Right layout */
.slide-container.bleed-image-layout {
  align-items: start;
  display: grid;
  gap: 50px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  padding: 0;
}

.slide-container.bleed-image-layout > .content-container {
  padding: 60px 0 60px 60px;
  display: flex;
  flex-direction: column;
  height: 100%;
  justify-content: center;
}

.slide-container.bleed-image-layout > .image-container {
  height: 100%;
  overflow: hidden;
  width: 100%;
}

.slide-container.bleed-image-layout img.bleed-image-side {
  display: block;
  height: 720px;
  object-fit: cover;
  object-position: center;
  width: 100%;
}

.slide-container.bleed-image-layout .bleed-text-side p {
  color: #475569;
  line-height: 1.6;
  margin-bottom: 20px;
  font-size: 20px;
}

.slide-container.bleed-image-layout .slide-title {
  margin-bottom: 30px;
}
    </style>
</head>
